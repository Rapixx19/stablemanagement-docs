# ─────────────────────────────────────────────────────────────────────────────
# Stableplatform — environment variables template
# ─────────────────────────────────────────────────────────────────────────────
#
# HOW TO USE THIS FILE
#
# 1. Copy this file to `.env.local` at the same level as your apps/web/
#    (i.e., the project root once slice 00 has created apps/web/). Local dev
#    reads from .env.local. The file is gitignored — never commit it.
# 2. For Vercel: paste each var into the project's Environment Variables
#    settings (Production + Preview + Development). Mark sensitive ones as
#    "Sensitive" so they're hidden in the dashboard after save.
# 3. Source of truth for the actual values: 1Password team vault under
#    `STBL_<TIER>_<SERVICE>` naming convention.
# 4. Two values you GENERATE yourself (not from a vendor):
#       CRON_SECRET                 — `openssl rand -base64 32`
#       BEXIO_TOKEN_ENCRYPTION_KEY  — `openssl rand -base64 32`
#
# Variable naming convention:
#   NEXT_PUBLIC_*  → exposed to the browser bundle. Never put a secret here.
#   (no prefix)    → server-only. Default for everything else.
#
# Reference: docs/domains/secrets.md (storage + rotation policy)
#            docs/.cursorrules.md  (the "never commit secrets" rule)
# ─────────────────────────────────────────────────────────────────────────────


# ═════════════════════════════════════════════════════════════════════════════
# TIER 1 — CRITICAL (slice 00 cannot ship without these)
# ═════════════════════════════════════════════════════════════════════════════

# ── Supabase ────────────────────────────────────────────────────────────────
# Get from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# Server-only. NEVER expose in browser bundle. Service role bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# Direct DB connection (used by migrations + pg_cron only)
# Get from: Settings → Database → Connection string (Direct)
SUPABASE_DB_DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Transaction-mode pooler (used by app traffic per D8)
# Get from: Settings → Database → Connection string (Transaction)
SUPABASE_DB_POOLER_URL=postgresql://postgres.YOUR_PROJECT_REF:[YOUR-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Project ref (for Supabase CLI + MCP)
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF


# ── Vercel + Cron ────────────────────────────────────────────────────────────
# Generate yourself: openssl rand -base64 32
# Used by every /api/cron/* handler to verify Vercel Cron requests (D12).
CRON_SECRET=


# ── Resend (transactional email) ─────────────────────────────────────────────
# Get from: resend.com → API Keys
# Verify your sender domain (lafattoria.app) FIRST, then create a sending key.
RESEND_API_KEY=re_...

# Get from: resend.com → Inbound → Webhook signing secret
# Used by /api/inbound/documents to verify webhook signatures (slice 01b).
RESEND_INBOUND_WEBHOOK_SECRET=

# Sender domain (must be verified in Resend with SPF/DKIM/DMARC)
RESEND_SENDER_DOMAIN=lafattoria.app


# ── Reducto (document extraction) ────────────────────────────────────────────
# Get from: reducto.ai → API Settings
# Requires signed DPA for EU residency + no model-training on customer data.
REDUCTO_API_KEY=
REDUCTO_API_BASE=https://api.reducto.ai


# ── OpenAI (embeddings) ──────────────────────────────────────────────────────
# Get from: platform.openai.com → API Keys → Create new secret key
# Scope to "embedding" permission only if available.
OPENAI_EMBEDDING_API_KEY=sk-proj-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small


# ── Anthropic (Claude) ───────────────────────────────────────────────────────
# Get from: console.anthropic.com → API Keys
# Used by slice 05 catalog extraction (Sonnet 4.6) + slice 01b document triage (Haiku 4.5).
ANTHROPIC_API_KEY=sk-ant-api03-...


# ── Bexio (OAuth integration) ────────────────────────────────────────────────
# Get from: bexio.com → Developer Portal → OAuth Apps → Create app
# Dev sandbox first; production credentials when La Fattoria onboards.
BEXIO_CLIENT_ID=
BEXIO_CLIENT_SECRET=
BEXIO_API_BASE=https://api.bexio.com

# Generate yourself: openssl rand -base64 32
# Symmetric key for pgcrypto encryption of OAuth tokens in DB (D8).
# Loss of this key = re-authorize every stable's Bexio connection.
# Backup in 1Password + separately in Supabase Vault.
BEXIO_TOKEN_ENCRYPTION_KEY=


# ═════════════════════════════════════════════════════════════════════════════
# TIER 2 — IMPORTANT (observability + ops; blocks slice ~08 onwards)
# ═════════════════════════════════════════════════════════════════════════════

# ── Sentry (errors + performance) ────────────────────────────────────────────
# Get from: sentry.io → Settings → Projects → Client Keys (DSN)
# Use EU region. Separate DSN for browser bundle (public) vs. server (server-only).
NEXT_PUBLIC_SENTRY_DSN=https://...@oXXXXXX.ingest.sentry.io/...
SENTRY_DSN=https://...@oXXXXXX.ingest.sentry.io/...

# Server-only. For source-map upload during build.
# Get from: Settings → Account → Auth Tokens (org-level)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=stableplatform
SENTRY_PROJECT=web


# ── Better Stack (or Axiom) — Pino log sink ──────────────────────────────────
# Pick one provider. EU region, 30-day retention minimum.
# Get from: betterstack.com → Logs → Sources → API tokens
BETTER_STACK_TOKEN=
# Alternative:
# AXIOM_TOKEN=
# AXIOM_DATASET=stableplatform


# ── UptimeRobot ──────────────────────────────────────────────────────────────
# No API key needed. UptimeRobot pings /api/healthz directly.
# Configure manually in uptimerobot.com → Add Monitor → HTTP(S) on
# https://app.lafattoria.app/api/healthz with alert routing to Slack.


# ═════════════════════════════════════════════════════════════════════════════
# TIER 3 — PRE-LAUNCH ONLY (blocks pilot, not slice 00)
# ═════════════════════════════════════════════════════════════════════════════

# ── SIX QR-bill validator ────────────────────────────────────────────────────
# Get from: paymentstandards.ch → request validator API access (Swiss banking org, slow)
# Used in CI to validate generated QR-bill PDFs (slice 08 acceptance).
SIX_VALIDATOR_USERNAME=
SIX_VALIDATOR_PASSWORD=


# ═════════════════════════════════════════════════════════════════════════════
# APP CONFIGURATION
# ═════════════════════════════════════════════════════════════════════════════

# In local dev: http://localhost:3000
# In production: https://app.lafattoria.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Inbound mail domain for slice 01b document ingestion (MX records → Resend)
NEXT_PUBLIC_INBOX_DOMAIN=inbox.stableplatform.ch

# Standard Node env (Vercel sets this automatically in prod; set locally if needed)
NODE_ENV=development

# Locale defaults (slice 00 onboarding picks per-stable)
NEXT_PUBLIC_DEFAULT_LOCALE=de


# ═════════════════════════════════════════════════════════════════════════════
# OPTIONAL — local dev convenience (not used in production)
# ═════════════════════════════════════════════════════════════════════════════

# Direct local Supabase if you're running `supabase start` instead of cloud
# LOCAL_SUPABASE_URL=http://localhost:54321
# LOCAL_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# Override AI cost caps for testing (defaults documented in domain docs)
# REDUCTO_COST_CAP_USD=50
# OPENAI_EMBEDDING_COST_CAP_USD=20
# ANTHROPIC_COST_CAP_USD=25


# ─────────────────────────────────────────────────────────────────────────────
# DO NOT COMMIT THIS FILE WITH REAL VALUES.
# .env.local + .env + .env.*.local are already in docs/.gitignore.
# If you ever paste a real key here, immediately rotate it and remove it.
# Gitleaks pre-commit hook will block accidental commits — don't bypass it.
# ─────────────────────────────────────────────────────────────────────────────
